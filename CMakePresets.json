{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "${sourceDir}/cmake/toolchains/gcc.cmake"
    },
    {
      "name": "debug",
      "inherits": "_base",
      "displayName": "Debug (system GCC)",
      "description": "Fast dev build with assertions and debug info.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-D_GLIBCXX_ASSERTIONS"
      }
    },
    {
      "name": "release",
      "inherits": "_base",
      "displayName": "RelWithDebInfo (system GCC)",
      "description": "Optimised build with debug info.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "sanitize",
      "inherits": "_base",
      "displayName": "ASan+UBSan (system GCC)",
      "description": "Debug build under AddressSanitizer and UndefinedBehaviorSanitizer.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS":
            "-D_GLIBCXX_ASSERTIONS -D_GLIBCXX_USE_TBB_PAR_BACKEND=0 -fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "sanitize",
      "configurePreset": "sanitize"
    }
  ],
  "testPresets": [
    {
      "name": "_test-base",
      "hidden": true,
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "inherits": "_test-base"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "inherits": "_test-base"
    },
    {
      "name": "sanitize",
      "configurePreset": "sanitize",
      "inherits": "_test-base"
    }
  ]
}
